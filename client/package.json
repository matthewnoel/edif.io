{
	"name": "edif-io-client",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host 0.0.0.0",
		"build": "vite build",
		"preview": "vite preview --host 0.0.0.0",
		"prepare": "svelte-kit sync && npm run paraglide:compile || echo ''",
		"paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"leetify": "node scripts/leetify.mjs",
		"leetify:check": "node scripts/leetify.mjs --check",
		"check": "npm run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "npm run paraglide:compile && prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "npm run paraglide:compile && vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"test:e2e:fullstack": "playwright test --config=playwright.fullstack.config.ts",
		"generate:favicon": "curl -sL https://raw.githubusercontent.com/matthewnoel/emoji-favicon-generator/main/generate-favicon.mjs -o .generate-favicon.tmp.mjs && node .generate-favicon.tmp.mjs 🧠; rm -f .generate-favicon.tmp.mjs"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@inlang/paraglide-js": "^2.18.2",
		"@inlang/plugin-message-format": "^4.4.0",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.63.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^25",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"sharp": "^0.34.5",
		"svelte": "^5.55.9",
		"svelte-check": "^4.4.8",
		"to-ico": "^1.1.5",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.4",
		"vite": "^8.0.14",
		"vitest": "^4.1.7"
	}
}
